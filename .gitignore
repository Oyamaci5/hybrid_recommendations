# Ignore everything except data and results directories

.gitignore
data/*
!data/*.py
results/
google_apps_script/
# Explicitly ignore .cursor directory
.cursor/
*.txt
*.xlsx
*.csv

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# Environment files
.env
.env.local
venv/
env/

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*.swn
*.code-workspace

# OS files
.DS_Store
.DS_Store?
Thumbs.db
