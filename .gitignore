# Ignore everything except data and results directories

.gitignore
data/
results/**
!results/**/
!results/**/*.sqlite
!results/**/*.png
mealpy/results/**
!mealpy/results/**/
!mealpy/results/**/*.sqlite
!mealpy/results/**/*.png
comparison_algorithms/results/**
!comparison_algorithms/results/**/
!comparison_algorithms/results/**/*.sqlite
!comparison_algorithms/results/**/*.png
google_apps_script/
# Explicitly ignore .cursor directory
.cursor/
*.txt
*.xlsx
*.csv
*.npy

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# Environment files
.env
.env.local
venv/
env/

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*.swn
*.code-workspace

# OS files
.DS_Store
.DS_Store?
Thumbs.db
